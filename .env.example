# Copy to .env for local dev. NEVER commit .env.
# --- Postgres ---
POSTGRES_USER=stocks
POSTGRES_PASSWORD=stocks_dev_only
POSTGRES_DB=stocks
DATABASE_URL=postgres://stocks:stocks_dev_only@localhost:5432/stocks?sslmode=disable

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- LLM provider (swappable transports; see internal/platform/llm) ---
# LLM_PROVIDER ∈ { mock | anthropic | openai_compat }
#
# anthropic-shape (works with Anthropic, z.ai, Bedrock, Vertex):
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic   # or api.anthropic.com
#   ANTHROPIC_AUTH_TOKEN=<your key>
#
# openai-shape (DeepSeek, Together, OpenRouter, vLLM, Groq):
#   LLM_PROVIDER=openai_compat
#   OPENAI_BASE_URL=https://api.deepseek.com
#   OPENAI_API_KEY=<sk-...>
LLM_PROVIDER=mock
LLM_MODEL_DEEP=claude-opus-4-8
LLM_MODEL_ROUTINE=glm-4.6
LLM_MODEL_TRIAGE=glm-4.5-air

ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=
OPENAI_BASE_URL=
OPENAI_API_KEY=

# --- Gateway ---
GATEWAY_ADDR=:8080

# --- Data sources (free MVP) ---
# SEC requires a descriptive User-Agent with contact email.
SEC_EDGAR_UA="stocks-research n@noeljackson.com"
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
# Without it, the FRED adapter no-ops (the keyless CSV endpoint is bot-blocked).
FRED_API_KEY=
