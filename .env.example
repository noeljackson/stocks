# Copy to .env for local dev. NEVER commit .env.
# --- Postgres ---
POSTGRES_USER=stocks
POSTGRES_PASSWORD=stocks_dev_only
POSTGRES_DB=stocks
DATABASE_URL=postgres://stocks:stocks_dev_only@localhost:5432/stocks?sslmode=disable

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- LLM provider (abstraction; subscription or API) ---
# PROVIDER is one of: subscription | anthropic | mock
LLM_PROVIDER=mock
LLM_MODEL_DEEP=claude-opus-4-8
LLM_MODEL_ROUTINE=claude-sonnet-4-6
LLM_MODEL_TRIAGE=claude-haiku-4-5
# ANTHROPIC_API_KEY=   # only if LLM_PROVIDER=anthropic

# --- Gateway ---
GATEWAY_ADDR=:8080

# --- Data sources (free MVP) ---
# SEC requires a descriptive User-Agent with contact email.
SEC_EDGAR_UA="stocks-research n@noeljackson.com"
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
# Without it, the FRED adapter no-ops (the keyless CSV endpoint is bot-blocked).
FRED_API_KEY=
