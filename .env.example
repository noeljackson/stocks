# Copy to .env for local dev. NEVER commit .env.
# --- Postgres ---
POSTGRES_USER=stocks
POSTGRES_PASSWORD=stocks_dev_only
POSTGRES_DB=stocks
DATABASE_URL=postgres://stocks:stocks_dev_only@localhost:5432/stocks?sslmode=disable

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- LLM (zero-config: just drop a key in) ---------------------------------
# Transport auto-detects from credentials. To go live with z.ai, ONLY set:
#   ANTHROPIC_API_KEY=<your z.ai key>
# Everything else has sensible defaults.
#
# To override the transport explicitly, set LLM_PROVIDER ∈ {anthropic|openai_compat|mock}.
# Otherwise: ANTHROPIC_API_KEY present → anthropic; OPENAI_BASE_URL+OPENAI_API_KEY → openai_compat;
# neither → mock.
LLM_PROVIDER=
LLM_MODEL_DEEP=glm-5.1
LLM_MODEL_ROUTINE=glm-5.1
LLM_MODEL_TRIAGE=glm-5-turbo

# z.ai is the default Anthropic-shape endpoint; for Anthropic direct set
# ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_API_KEY=

# Optional OpenAI-shape backend (DeepSeek, Together, OpenRouter, vLLM, Groq).
# Auto-detected if BOTH base_url and api_key are set.
OPENAI_BASE_URL=
OPENAI_API_KEY=

# --- Gateway ---
GATEWAY_ADDR=:8080

# --- Cognition freshness loop ---
COGNITION_SWEEP_SECONDS=300
COGNITION_OPEN_THESIS_MAX_AGE_MINUTES=30
COGNITION_MAX_SYMBOLS_PER_SWEEP=20
COGNITION_MIN_SYMBOLS_PER_SWEEP=20
COGNITION_SWEEP_CONCURRENCY=2

# --- Data sources (free MVP) ---
# SEC requires a descriptive User-Agent with contact email.
SEC_EDGAR_UA="stocks-research n@noeljackson.com"
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
# Without it, the FRED adapter no-ops (the keyless CSV endpoint is bot-blocked).
FRED_API_KEY=

# Optional local/hosted Firecrawl web retrieval. Start local self-hosted
# Firecrawl with `make firecrawl-up`, then enable with:
#   RESEARCH_PROVIDER=gdelt,bing_news,firecrawl
FIRECRAWL_BASE_URL=http://localhost:3002
FIRECRAWL_API_KEY=
FIRECRAWL_SEARCH_PATH=/v2/search
FIRECRAWL_SEARCH_TBS=qdr:m

# --- IBKR read-only broker sync ---
# TWS/IB Gateway paper defaults to 7497; live is commonly 7496.
# In Docker against host TWS/Gateway, use `make ibkr-up` and leave host as
# host.docker.internal. For managed IB Gateway in compose, use
# `make ibkr-stack-up`; credentials still belong in Infisical dev, not .env.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=81
IBKR_ACCOUNT=
IBKR_READONLY=true
IBKR_TIMEOUT_SECONDS=6
IBKR_SYNC_INTERVAL_SECONDS=30
IBKR_GATEWAY_IMAGE=ghcr.io/gnzsnz/ib-gateway:10.45.1h
IBKR_TRADING_MODE=paper
IBKR_GATEWAY_READ_ONLY_API=yes
IBKR_TWS_ACCEPT_INCOMING=accept
IBKR_GATEWAY_LIVE_PORT=4001
IBKR_GATEWAY_PAPER_PORT=4002
IBKR_GATEWAY_VNC_PORT=15900
IBKR_GATEWAY_TIME_ZONE=Europe/Amsterdam
IBKR_TWOFA_TIMEOUT_ACTION=restart
IBKR_RELOGIN_AFTER_TWOFA_TIMEOUT=yes
TWS_USERID=
TWS_PASSWORD=
TWS_USERID_PAPER=
TWS_PASSWORD_PAPER=
VNC_SERVER_PASSWORD=

# Massive.com (Polygon-compatible REST). Stocks Starter tier ~$29/mo gets
# unlimited calls + 5y daily history; without a key the price adapter no-ops.
# Override base for a self-hosted Polygon compat (vLLM-of-prices style).
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
