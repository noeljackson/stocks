# Go
/bin/
*.test
*.out

# Node / frontend
/web/node_modules/
# Built SPA assets are regenerated by `make web-build`; a placeholder index.html
# is committed so `go:embed` compiles before the first frontend build.
/internal/web/dist/assets/
/internal/web/dist/*.js
/internal/web/dist/*.css

# Python
__pycache__/
*.pyc
/py/.venv/
/py/dist/
*.egg-info/

# Env / secrets — never commit
.env
.env.*
!.env.example
*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
.claude/

# UEFI firmware variable dumps (accidentally landed in workdir)
NvVars
