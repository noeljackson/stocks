# Rust
/target/
**/*.rs.bk
Cargo.lock.bak

# Node / frontend
/web/node_modules/
# Built SPA assets are regenerated by `make web-build`; a placeholder
# index.html is committed so `rust-embed` compiles before the first build.
/web/dist/assets/
/web/dist/*.js
/web/dist/*.css
/web/test-results/
/web/playwright-report/
/web/.cache/
/.runtime/

# Python
__pycache__/
*.pyc
/py/.venv/
/py/dist/
*.egg-info/

# Env / secrets — never commit
.env
.env.*
!.env.example
*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
.claude/

# UEFI firmware variable dumps (accidentally landed in workdir)
NvVars
